// E2E test override — auto-allow Gatepath helper actions without prompting.
//
// The shipped policy at /usr/share/polkit-1/actions/com.ventouxlabs.Gatepath.NetNsHelper.policy
// defaults both actions to "auth_admin_keep", which requires a logind session
// + a polkit authentication agent (gnome-shell, lxqt-policykit, etc.) we
// don't have inside the container. This override sits at higher priority
// (50-* > 49-* shipped distro defaults) and returns YES for both actions.
//
// Test scope only — not installed on real systems.
polkit.addRule(function(action, subject) {
    if (action.id.indexOf("com.ventouxlabs.Gatepath.NetNsHelper.") === 0) {
        return polkit.Result.YES;
    }
});
